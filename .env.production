# PeerJS signaling server — leave empty to use free PeerJS cloud (0.peerjs.com)
VITE_PEERJS_HOST=
VITE_PEERJS_PORT=
VITE_PEERJS_PATH=

# TURN relay — required for cross-network calls (peers on different WiFi/cellular).
# Without TURN, only same-network or simple NAT connections will work.
# Free option: sign up at https://www.metered.ca/stun-turn (500GB/month free).
VITE_TURN_HOST=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
