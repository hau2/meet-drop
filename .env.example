# PeerJS signaling server configuration
# Dev: point to local peerjs-server (npm install -g peerjs && peerjs --port 9000)
# Prod: point to your Railway-deployed peerjs-server URL (e.g., your-app.railway.app)
VITE_PEERJS_HOST=localhost
VITE_PEERJS_PORT=9000
VITE_PEERJS_PATH=/peerjs

# TURN server credentials for NAT traversal
# Dev: uses Metered Open Relay (openrelayproject / openrelayproject) — 20 GB/month free
# Prod: use Cloudflare TURN — Dashboard -> Realtime -> TURN -> Create TURN key
VITE_TURN_USERNAME=openrelayproject
VITE_TURN_CREDENTIAL=openrelayproject
