# PeerJS signaling server configuration
# Dev: point to local peerjs-server (npm run dev starts one on port 9000)
# Prod: leave empty to use free PeerJS cloud, or point to your own server
VITE_PEERJS_HOST=localhost
VITE_PEERJS_PORT=9000
VITE_PEERJS_PATH=/peerjs

# TURN relay — required for cross-network calls (different WiFi/cellular)
# Without TURN, only same-network connections will work.
# Free option: sign up at https://www.metered.ca/stun-turn (500GB/month free)
VITE_TURN_HOST=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
